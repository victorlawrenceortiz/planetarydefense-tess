[Unit]
Description=Serve PDF live orbital diagram over HTTP
After=network-online.target
Wants=network-online.target
[Service]
Type=simple
WorkingDirectory=/var/lib/pdf-orbital-diagram
ExecStart=/usr/bin/python3 -m http.server 9090 --bind 0.0.0.0
Restart=always
RestartSec=2
[Install]
WantedBy=multi-user.target
