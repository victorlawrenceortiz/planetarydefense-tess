[Unit]
Description=PDF Impact Scenario API
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/pdf/impact-sim
ExecStart=/opt/pdf/trajectory/.venv/bin/uvicorn impact_sim_api:app --host 0.0.0.0 --port 9200
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target
