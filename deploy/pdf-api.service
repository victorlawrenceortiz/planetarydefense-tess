[Unit]
Description=PDF Pipeline API
After=network-online.target postgresql.service
Wants=network-online.target

[Service]
Type=simple
ExecStart=/opt/pdf/venv/bin/uvicorn api:APP --host 0.0.0.0 --port 8787
WorkingDirectory=/opt/pdf/app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
